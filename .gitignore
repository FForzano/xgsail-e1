# --- Firmware build output ---------------------------------------------
# arduino-cli --export-binaries writes here; the CI workflow publishes
# these as release assets instead of committing them.
firmware/**/build/
*.bin
*.elf
*.map
*.hex

# PlatformIO
.pio/
.pioenvs/
.piolibdeps/

# Arduino IDE 2.x per-sketch state
firmware/**/.theia/
firmware/**/sketch.yaml.bak

# --- Device-owned / secret-bearing files -------------------------------
# config.txt in the sketch dir is the committed sample; a real card's
# copy holds WiFi passwords and a claim code — never commit those, nor
# the firmware-owned files described in firmware/README.md.
device.txt
boot.log
imu_cal.txt
wind_mac.txt
!firmware/e1_sd_card/imu_cal.txt
!firmware/e1_sd_card/wind_mac.txt

# Recorded sessions pulled off an SD card for debugging
sf/
*_nav.csv
*_imu.csv
*_wind.csv
*_pres.csv

# --- KiCad ------------------------------------------------------------
# Sources, footprints, Gerbers and the BOM are tracked; these are
# regenerated or local-only.
*-backups/
*.kicad_prl
*.kicad_pcb-bak
*.kicad_sch-bak
*.kicad_pro-bak
*.bak
*.000
fp-info-cache
~*.lck
_autosave-*
*.net
*-erc.rpt
*-drc.rpt

# --- Editors / OS ------------------------------------------------------
.DS_Store
._*
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*~
